# Копирай този файл в /etc/nginx/sites-available/dsnow
# и направи symlink: sudo ln -s /etc/nginx/sites-available/dsnow /etc/nginx/sites-enabled/

server {
    listen 80;
    server_name dsnow.yourdomain.com;   # <-- смени с твоя домейн или IP

    # React build файловете
    root /var/www/dsnow/client/dist;
    index index.html;

    location / {
        try_files $uri /index.html;
    }

    # Проксира /api заявките към Node сървъра, управляван от PM2
    location /api/ {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
